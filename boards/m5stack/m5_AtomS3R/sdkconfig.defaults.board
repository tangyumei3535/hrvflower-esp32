CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_MEMTEST=n
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=2048
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=98304
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
CONFIG_ESP_CONSOLE_UART_NUM=-1

# HRV low power + BMI270 any-motion wake (AtomS3R)
CONFIG_HRV_LOW_POWER_ENABLE=y
CONFIG_HRV_ACTIVE_WINDOW_SEC=90
CONFIG_HRV_IMU_WAKE_ENABLE=y
CONFIG_HRV_IMU_INT_GPIO=16
CONFIG_HRV_IMU_I2C_SDA_GPIO=45
CONFIG_HRV_IMU_I2C_SCL_GPIO=0

# USER button (GPIO41) + Atomic Battery Base BAT ADC (AtomS3R = GPIO8 per M5 docs)
CONFIG_HRV_USER_BTN_ENABLE=y
CONFIG_HRV_BATTERY_ADC_ENABLE=y
CONFIG_HRV_BATTERY_ADC_GPIO=8
