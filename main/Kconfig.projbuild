menu "HRV Emotion Flower"

    config HRV_WIFI_SSID
        string "Default Wi-Fi SSID (optional seed)"
        default ""
        help
            If NVS has no saved networks, this SSID/password pair is written once
            on first boot. Leave empty to force captive-portal setup instead.

    config HRV_WIFI_PASSWORD
        string "Default Wi-Fi password"
        default ""
        help
            Password paired with HRV_WIFI_SSID for the one-time NVS seed.

    config BEMFA_PRIVATE_KEY
        string "Bemfa private key (UID)"
        default ""
        help
            Your Bemfa cloud private key (UID). Used in HTTP POST uid field.
            In single-device mode, also used as MQTT client_id.

    choice BEMFA_MQTT_AUTH_MODE
        prompt "Bemfa MQTT authentication mode"
        default BEMFA_MQTT_AUTH_UID
        help
            Bemfa mode 1: client_id must equal UID (one board per UID).
            Bemfa mode 2: unique client_id + AppID/secretKey (multi-device).

        config BEMFA_MQTT_AUTH_UID
            bool "UID as client_id (single device)"
            help
                Standard Bemfa auth. Only one board can hold an MQTT session
                per UID; a second board with the same UID will kick the first.

        config BEMFA_MQTT_AUTH_APPKEY
            bool "AppID + secretKey (multi-device)"
            help
                Unique client_id per board (Wi-Fi MAC) with username=AppID and
                password=secretKey. Multiple boards can subscribe to the same topic.
                Generate credentials via Bemfa API (see help for App ID field).

    endchoice

    config BEMFA_MQTT_APP_ID
        string "Bemfa MQTT App ID"
        depends on BEMFA_MQTT_AUTH_APPKEY
        default ""
        help
            AppID for Bemfa auth mode 2. Generate with:
            curl -X POST https://pro.bemfa.com/vs/web/v1/userSecretKey \\
              -H "Content-Type: application/json" \\
              -d '{"openID":"<your UID>"}'

    config BEMFA_MQTT_SECRET_KEY
        string "Bemfa MQTT secret key"
        depends on BEMFA_MQTT_AUTH_APPKEY
        default ""
        help
            secretKey paired with BEMFA_MQTT_APP_ID (same API call as App ID).

    config BEMFA_MQTT_TOPIC
        string "Bemfa MQTT topic name"
        default "hrv001"
        help
            Topic created in Bemfa console. iOS Shortcut should POST to this topic.

    config BEMFA_MQTT_BROKER_URI
        string "MQTT broker URI"
        default "mqtt://bemfa.com:9501"
        help
            Bemfa MQTT broker. Plain TCP port 9501 per official documentation.

    menu "Low power (deep sleep)"

        config HRV_LOW_POWER_ENABLE
            bool "Enable deep sleep after active window"
            default n
            help
                After the last valid MQTT payload, stay awake HRV_ACTIVE_WINDOW_SEC,
                then turn off backlight and enter deep sleep. No RTC timer wake.
                NVS-cached UI is shown after wake. AtomS3R: optional BMI270 EXT1 wake.

        config HRV_ACTIVE_WINDOW_SEC
            int "Idle time after last MQTT before deep sleep (seconds)"
            depends on HRV_LOW_POWER_ENABLE
            default 90
            range 10 600
            help
                Each valid MQTT payload resets this idle timer. Deep sleep starts
                when no new payload arrives for this many seconds.

        config HRV_IMU_WAKE_ENABLE
            bool "BMI270 any-motion wake from deep sleep (AtomS3R)"
            depends on HRV_LOW_POWER_ENABLE
            default y
            help
                Configure on-board BMI270 (Toy firmware) for any-motion on INT1.
                Wake via ESP32-S3 EXT1 on RTC GPIO (default 16). Side reset (EN) always wakes.

        config HRV_IMU_INT_GPIO
            int "BMI270 INT1 GPIO (RTC 0-21; NOT GPIO3=32K crystal)"
            depends on HRV_IMU_WAKE_ENABLE
            default 16
            range 0 21

        config HRV_IMU_I2C_SDA_GPIO
            int "BMI270 I2C SDA GPIO"
            depends on HRV_IMU_WAKE_ENABLE
            default 45
            range 0 48

        config HRV_IMU_I2C_SCL_GPIO
            int "BMI270 I2C SCL GPIO"
            depends on HRV_IMU_WAKE_ENABLE
            default 0
            range 0 48

    endmenu

endmenu
